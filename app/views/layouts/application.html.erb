<!DOCTYPE html>
<html class="h-full bg-slate-50">
  <head>
    <title><%= content_for(:title) || "Comments & Notifications" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full text-slate-800 antialiased">
    <% if user_signed_in? %>
      <%= turbo_stream_from current_user, :notifications %>
    <% end %>

    <header class="bg-white border-b border-slate-200 shadow-sm">
      <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <%= link_to "Comments", root_path, class: "text-xl font-bold text-indigo-700 hover:text-indigo-900" %>
          <% if user_signed_in? %>
            <%= link_to notifications_path, class: "relative text-slate-600 hover:text-indigo-700 font-medium" do %>
              Notifications
              <%= render "shared/notifications_badge", count: current_user.notifications.unread.count %>
            <% end %>
          <% end %>
        </div>
        <div class="flex items-center gap-4 text-sm">
          <% if user_signed_in? %>
            <span class="text-slate-500">Signed in as <span class="font-semibold text-slate-800">@<%= current_user.username %></span></span>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "px-3 py-1.5 rounded-md bg-slate-200 hover:bg-slate-300 text-slate-800 font-medium" %>
          <% else %>
            <%= link_to "Log in", new_user_session_path, class: "px-3 py-1.5 rounded-md bg-indigo-600 hover:bg-indigo-700 text-white font-medium" %>
            <%= link_to "Sign up", new_user_registration_path, class: "px-3 py-1.5 rounded-md border border-indigo-600 text-indigo-700 hover:bg-indigo-50 font-medium" %>
          <% end %>
        </div>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 py-8">
      <% if notice %>
        <div class="mb-4 rounded-md bg-emerald-50 border border-emerald-200 px-4 py-3 text-emerald-800"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="mb-4 rounded-md bg-rose-50 border border-rose-200 px-4 py-3 text-rose-800"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
