<%= form_with model: comment, class: "space-y-3" do |f| %>
  <% if comment.errors.any? %>
    <div class="rounded-md bg-rose-50 border border-rose-200 px-4 py-3 text-rose-800">
      <ul class="list-disc pl-5">
        <% comment.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= f.text_area :body,
        rows: 3,
        placeholder: "Write a comment... mention someone with @username",
        class: "w-full rounded-md border border-slate-300 px-3 py-2 focus:border-indigo-500 focus:ring focus:ring-indigo-100 focus:outline-none" %>

  <div class="flex items-center justify-end gap-2">
    <% if comment.persisted? %>
      <%= link_to "Cancel", root_path, class: "px-3 py-1.5 rounded-md bg-slate-100 hover:bg-slate-200 text-slate-700" %>
    <% end %>
    <%= f.submit class: "px-4 py-1.5 rounded-md bg-indigo-600 hover:bg-indigo-700 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
