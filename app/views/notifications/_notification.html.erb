<article id="<%= dom_id(notification) %>" class="flex items-start justify-between gap-4 p-4 rounded-lg border <%= notification.read? ? 'bg-white border-slate-200' : 'bg-indigo-50 border-indigo-200' %>">
  <div class="flex-1 min-w-0">
    <div class="text-sm text-slate-700">
      <span class="font-semibold text-indigo-700">@<%= notification.actor.username %></span>
      mentioned you in a comment
    </div>
    <% if notification.comment %>
      <blockquote class="mt-1 text-slate-600 text-sm italic truncate">
        "<%= notification.comment.body.truncate(140) %>"
      </blockquote>
    <% end %>
    <div class="mt-1 text-xs text-slate-400"><%= time_ago_in_words(notification.created_at) %> ago</div>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <% if notification.comment %>
      <%= link_to "View", comment_path(notification.comment), class: "text-sm text-indigo-700 hover:underline" %>
    <% end %>
    <% unless notification.read? %>
      <%= button_to "Mark read", mark_as_read_notification_path(notification), method: :patch,
            class: "text-sm px-2 py-1 rounded bg-slate-200 hover:bg-slate-300 text-slate-700 cursor-pointer" %>
    <% end %>
  </div>
</article>
