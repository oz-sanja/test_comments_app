<% content_for :title, "Notifications" %>

<div class="space-y-4">
  <header class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-slate-800">Notifications</h1>
    <% if current_user.notifications.unread.any? %>
      <%= button_to "Mark all as read", mark_all_as_read_notifications_path, method: :patch,
            class: "px-3 py-1.5 rounded-md bg-slate-800 hover:bg-slate-900 text-white text-sm font-medium cursor-pointer" %>
    <% end %>
  </header>

  <div id="notifications_list" class="space-y-3">
    <% if @notifications.any? %>
      <%= render @notifications %>
    <% else %>
      <p class="text-slate-500 italic">No notifications yet.</p>
    <% end %>
  </div>
</div>
